def normalize_bbox(bbox, width, height):
    """Normalise les coordonnées (x, y, w, h) sur une échelle de 0-1000."""
    return [
        int(1000 * (bbox[0] / width)),        # x_min
        int(1000 * (bbox[1] / height)),       # y_min
        int(1000 * ((bbox[0] + bbox[2]) / width)), # x_max
        int(1000 * ((bbox[1] + bbox[3]) / height))  # y_max
    ]


def convert_to_ls2(image_path):
    # 1. Charger l'image et obtenir ses dimensions
    img = Image.open(image_path)
    w, h = img.size
    
    # 2. Obtenir les données de Tesseract
    data = pytesseract.image_to_data(img, output_type=pytesseract.Output.DICT)
    
    # 3. Construire la liste pour LayoutLM
    tokens = []
    bboxes = []
    
    for i in range(len(data['text'])):
        # On ignore les blocs vides (espaces)
        if int(data['conf'][i]) > 0: 
            word = data['text'][i]
            # Coordonnées Tesseract : [left, top, width, height]
            box = [data['left'][i], data['top'][i], data['width'][i], data['height'][i]]
            
            # Normalisation
            normalized_box = normalize_bbox(box, w, h)
            
            tokens.append(word)
            bboxes.append(normalized_box)
    
    # Exemple d'affichage du premier mot
    print(f"Mot: {tokens[0]}, Box Normalisée: {bboxes[0]}")





